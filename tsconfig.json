{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2016",
    
    /* Modules */
    "module": "commonjs",
    "paths": {
      "*": ["./node_modules/*", "./src/types/*"]
    },
    
    /* Emit */
    "outDir": "dist",
    
    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Type Checking - CHANGED THESE */
    "strict": false,
    "noImplicitAny": false,
    
    /* Completeness */
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "<node_internals>/**",
    "bin/**"
  ]
}
